BACKEND_PUBLIC_URL=https://your-service.onrender.com
DATABASE_URL=
# disable — для Internal Database URL на Render (рекомендовано)
# require — для External Database URL або зовнішнього Postgres
DATABASE_SSL_MODE=disable
POSTER_APPLICATION_ID=your-poster-app-id
POSTER_APPLICATION_SECRET=replace-me
POSTER_CONNECT_PATH=/poster/connect
POSTER_SETTINGS_PATH=/poster/settings
POSTER_REDIRECT_PATH=/poster/auth/callback
POSTER_SUCCESS_PATH=/poster/connect/success
POSTER_INSTALLATIONS_FILE=.data/poster-installations.json
POSTER_ACCOUNT_SETTINGS_FILE=.data/poster-account-settings.json
POSTER_API_TIMEOUT_MS=15000
SETTINGS_ENCRYPTION_SECRET=replace-with-long-random-secret
SHIPDAY_API_BASE_URL=https://api.shipday.com
SHIPDAY_API_KEY=
SHIPDAY_AUTH_MODE=basic
SHIPDAY_MOCK_MODE=true
SHIPDAY_TIMEOUT_MS=15000
# Токен для верифікації вхідних webhook-ів від Shipday (max 32 символи).
# Встановити тут і в Shipday Dashboard → Integrations → Webhook → Token.
SHIPDAY_WEBHOOK_TOKEN=
SHIPDAY_PICKUP_NAME=
SHIPDAY_PICKUP_PHONE=
SHIPDAY_PICKUP_ADDRESS=
SHIPDAY_PICKUP_FORMATTED_ADDRESS=
SHIPDAY_PICKUP_LAT=
SHIPDAY_PICKUP_LNG=
