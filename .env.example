# =====================================================================
# Docker Compose / Traefik
# =====================================================================
APP_NAME=poster-shipday-bridge
APP_DOMAIN=mamamia.workflo.space
TZ=Europe/Kyiv

# Має збігатись з external Traefik network на сервері
TRAEFIK_NETWORK=proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_TLS=true
TRAEFIK_CERTRESOLVER=letsencrypt

# =====================================================================
# PostgreSQL (контейнер у внутрішній мережі docker-compose)
# =====================================================================
POSTGRES_USER=poster_bridge
POSTGRES_PASSWORD=replace-with-strong-random
POSTGRES_DB=poster_bridge

# =====================================================================
# Poster
# =====================================================================
POSTER_APPLICATION_ID=
POSTER_APPLICATION_SECRET=

# =====================================================================
# Шифрування Shipday API keys у БД.
# Згенерувати: openssl rand -hex 32
# НЕ змінювати після першого запуску — інакше збережені налаштування стануть нечитабельними.
# =====================================================================
SETTINGS_ENCRYPTION_SECRET=

# =====================================================================
# TurboSMS
# =====================================================================
TURBOSMS_TOKEN=
TURBOSMS_SENDER=
TURBOSMS_MOCK_MODE=false

# =====================================================================
# Shipday
# Webhook token: max 32 символи, має збігатись зі Shipday Dashboard.
# Shipday API key і pickup-адреси задаються per-spot через settings page (БД).
# =====================================================================
SHIPDAY_WEBHOOK_TOKEN=
